{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"]
  },
  "JwtSettings": {
    "Issuer": "TravelAgency.Identity",
    "Audience": "TravelAgency",
    "ValidateLifetime": true
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}",
          "Methods": ["GET", "POST"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1/auth" },
          { "PathPrefix": "/identity" }
        ]
      },
      "catalog-public-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/catalog/{**catch-all}",
          "Methods": ["GET"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1" },
          { "PathPrefix": "/catalog" }
        ]
      },
      "catalog-manage-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "RequireManagerOrAdmin",
        "Match": {
          "Path": "/api/v1/catalog/{**catch-all}",
          "Methods": ["POST", "PUT", "PATCH", "DELETE"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1" },
          { "PathPrefix": "/catalog" }
        ]
      },
      "bookings-route": {
        "ClusterId": "booking-cluster",
        "AuthorizationPolicy": "RequireClient",
        "Match": {
          "Path": "/api/v1/bookings/{**catch-all}",
          "Methods": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1" },
          { "PathPrefix": "/bookings" }
        ]
      },
      "favorites-route": {
        "ClusterId": "booking-cluster",
        "AuthorizationPolicy": "RequireClient",
        "Match": {
          "Path": "/api/v1/favorites/{**catch-all}",
          "Methods": ["GET", "POST", "DELETE"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1" },
          { "PathPrefix": "/favorites" }
        ]
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "RequireClient",
        "Match": {
          "Path": "/api/v1/chat/{**catch-all}",
          "Methods": ["GET", "POST"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1" },
          { "PathPrefix": "/chat" }
        ]
      },
      "media-route": {
        "ClusterId": "media-cluster",
        "AuthorizationPolicy": "RequireClient",
        "Match": {
          "Path": "/api/v1/media/{**catch-all}",
          "Methods": ["GET", "POST", "DELETE"]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1" },
          { "PathPrefix": "/media" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://identity-service:8080"
          }
        }
      },
      "catalog-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://catalog-service:8080"
          }
        }
      },
      "booking-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://booking-service:8080"
          }
        }
      },
      "chat-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://chat-service:8080"
          }
        }
      },
      "media-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://media-service:8080"
          }
        }
      }
    }
  },
  "RateLimiting": {
    "Global": {
      "Limit": 200,
      "PeriodSeconds": 60
    },
    "General": {
      "Limit": 100,
      "PeriodSeconds": 1
    },
    "Auth": {
      "Limit": 5,
      "PeriodSeconds": 1
    }
  },
  "Cors": {
    "AllowedOrigins": ["https://travelagency.com"],
    "AllowedMethods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["Authorization", "Content-Type", "Accept", "X-Correlation-Id", "X-Request-ID", "Cache-Control"]
  },
  "Otel": {
    "Endpoint": "http://otel-collector:4317"
  },
  "HealthCheckEndpoints": {
    "Identity": "http://identity-service:8080/health/live",
    "Catalog": "http://catalog-service:8080/health/live",
    "Booking": "http://booking-service:8080/health/live",
    "Chat": "http://chat-service:8080/health/live",
    "Media": "http://media-service:8080/health/live"
  }
}
