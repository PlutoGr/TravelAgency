# Copy this file to .env and fill in real values before running docker compose.
# The .env file is git-ignored and must never be committed.

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=travel_admin
POSTGRES_PASSWORD=change_me_strong_password

# =============================================================================
# MinIO (S3-compatible object storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password

# =============================================================================
# Identity service — gRPC service-to-service authentication
# Generate a random value with: openssl rand -hex 32
# =============================================================================
GRPC_INTERNAL_SERVICE_TOKEN=change_me_random_token
